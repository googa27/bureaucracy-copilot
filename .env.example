# Bureaucracy Copilot — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override data directory
# BC_DATA_DIR=~/.bureaucracy_copilot

# Optional: override Google credentials path
# GOOGLE_CREDENTIALS_PATH=~/.bureaucracy_copilot/credentials.json
